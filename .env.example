# PostgreSQL Configuration
# Nombre de la base de datos
POSTGRES_DB=coda

# Usuario de PostgreSQL
POSTGRES_USER=postgres

# Contraseña de PostgreSQL - CAMBIAR EN PRODUCCIÓN
POSTGRES_PASSWORD=postgres

# Django Configuration
# Ambiente: development, staging, production
DJANGO_ENV=development

# Clave secreta de Django - GENERAR UNA NUEVA EN PRODUCCIÓN
# https://docs.djangoproject.com/en/stable/ref/settings/#secret-key
DJANGO_SECRET_KEY=

# Modo de depuración - DESACTIVAR EN PRODUCCIÓN
DJANGO_DEBUG=True

# RDS/Database Configuration
# Nombre de la base de datos
RDS_DB_NAME=coda

# Usuario de la base de datos
RDS_USERNAME=postgres

# Hostname del servidor de base de datos (usar 'db' en Docker)
RDS_HOSTNAME=db

# Puerto del servidor de base de datos
RDS_PORT=5432

# Contraseña de la base de datos - CAMBIAR EN PRODUCCIÓN
RDS_PASSWORD=postgres

# Application Configuration
# IP local o dirección del servidor
IP_COMPUTADORA=127.0.0.1

# Dominio para las tutorías - CAMBIAR SEGÚN EL ENTORNO
TUTORIAS_DOMINIO=localhost

# Email Configuration
# Dominio o correo de email
EMAIL_DOMAIN=ejemplo@correo.com

# Contraseña de la cuenta de email - CAMBIAR EN PRODUCCIÓN
EMAIL_HOST_PASSWORD=

# Configuración del correo de notificaciones
# Host SMTP para envío de notificaciones
NOTIFICATIONS_EMAIL_HOST=smtp.gmail.com

# Puerto SMTP
NOTIFICATIONS_EMAIL_PORT=587

# Timeout SMTP en segundos para evitar que la petición web se quede esperando demasiado
NOTIFICATIONS_EMAIL_TIMEOUT=8

# Habilitar TLS para SMTP (True/False)
NOTIFICATIONS_EMAIL_USE_TLS=True

# Usuario/cuenta usada para enviar notificaciones
NOTIFICATIONS_EMAIL_USER=tutorias.beta.uamc@gmail.com

# Contraseña o app-password de la cuenta de notificaciones
NOTIFICATIONS_EMAIL_PASSWORD=

# Remitente visible en el correo de notificaciones
NOTIFICATIONS_EMAIL_FROM=tutorias.beta.uamc@gmail.com

# URL absoluta del logo UAM para usar en correos HTML
NOTIFICATIONS_EMAIL_LOGO_URL=https://www.cua.uam.mx/public/assets/images/LogoUAMC_2025.png

# Direccion institucional (se muestra en pie del correo)
NOTIFICATIONS_UAM_ADDRESS=Av. Vasco de Quiroga 4871, Santa Fe Cuajimalpa, Cuajimalpa de Morelos, 05348, Ciudad de Mexico, CDMX

# URL de Google Maps de la ubicacion
NOTIFICATIONS_UAM_MAPS_URL=https://maps.google.com/?q=UAM+Cuajimalpa

# Telefono principal UAM
NOTIFICATIONS_UAM_PHONE=(55) 5814 6500

# Telefono de CODDAA
NOTIFICATIONS_CODDAA_PHONE=(55) 5814 6500

# Agrega el nombre del host local a allowed hosts para poder correr el proyecto sin problemas en diferentes computadoras (esta es opcional)
LOCAL_HOST_NAME=
